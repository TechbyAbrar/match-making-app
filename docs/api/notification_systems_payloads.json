{
  "info": {
    "name": "Blink — Notification System",
    "_postman_id": "blink-notifications-v1",
    "description": "Production-grade test collection for the Django + OneSignal notification system. Set {{base_url}} and {{token}} in your environment before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "http://localhost:8000",           "type": "string" },
    { "key": "token",        "value": "YOUR_JWT_OR_TOKEN_HERE",          "type": "string" },
    { "key": "player_id",    "value": "aabbccdd-1234-5678-abcd-000000000001", "type": "string" },
    { "key": "delivery_id",  "value": "",                                "type": "string" }
  ],
  "item": [
    {
      "name": "1 — Device Management",
