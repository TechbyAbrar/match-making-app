    {
      "name": "5 — Notification Preferences",
      "item": [
        {
          "name": "5.1 Get preferences — first fetch (auto-creates with all defaults true)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/notifications/preferences/", "host": ["{{base_url}}"], "path": ["api","notifications","preferences",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('push_enabled present',  () => pm.expect(b).to.have.property('push_enabled'));",
                  "pm.test('chat_message present',  () => pm.expect(b).to.have.property('chat_message'));",
                  "pm.test('call_incoming present', () => pm.expect(b).to.have.property('call_incoming'));",
                  "pm.test('call_missed present',   () => pm.expect(b).to.have.property('call_missed'));",
                  "pm.test('video_invite present',  () => pm.expect(b).to.have.property('video_invite'));",
                  "pm.test('story_new present',     () => pm.expect(b).to.have.property('story_new'));",
                  "pm.test('generic present',       () => pm.expect(b).to.have.property('generic'));"
                ]
              }
            }
          ]
        },
        {
          "name": "5.2 Update — disable all push globally",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"push_enabled\": false\n}"
            },
            "url": { "raw": "{{base_url}}/api/notifications/preferences/", "host": ["{{base_url}}"], "path": ["api","notifications","preferences",""] }
          },
