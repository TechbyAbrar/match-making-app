    {
      "name": "2 — In-App Inbox",
      "item": [
        {
          "name": "2.1 List notifications — default page_size 30",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications/?page_size=30",
              "host": ["{{base_url}}"],
              "path": ["api","notifications",""],
              "query": [{ "key": "page_size", "value": "30" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "const body = pm.response.json();",
                  "if (body.length > 0) {",
                  "  const item = body[0];",
                  "  pm.test('Item has id',         () => pm.expect(item).to.have.property('id'));",
                  "  pm.test('Item has type',        () => pm.expect(item).to.have.property('type'));",
                  "  pm.test('Item has title',       () => pm.expect(item).to.have.property('title'));",
                  "  pm.test('Item has body',        () => pm.expect(item).to.have.property('body'));",
                  "  pm.test('Item has data',        () => pm.expect(item).to.have.property('data'));",
                  "  pm.test('Item has is_read',     () => pm.expect(item).to.have.property('is_read'));",
                  "  pm.test('Item has status',      () => pm.expect(item).to.have.property('status'));",
                  "  pm.test('Item has created_at',  () => pm.expect(item).to.have.property('created_at'));",
                  "  pm.collectionVariables.set('delivery_id', item.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 List notifications — small page_size 5",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications/?page_size=5",
              "host": ["{{base_url}}"],
              "path": ["api","notifications",""],
              "query": [{ "key": "page_size", "value": "5" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Max 5 items returned', () => pm.expect(pm.response.json().length).to.be.at.most(5));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 List notifications — page_size above 100 cap (must return ≤100)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications/?page_size=9999",
              "host": ["{{base_url}}"],
              "path": ["api","notifications",""],
              "query": [{ "key": "page_size", "value": "9999" }]
