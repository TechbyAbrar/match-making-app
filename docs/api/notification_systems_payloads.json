        {
          "name": "1.1 Register device — Android (happy path)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onesignal_player_id\": \"{{player_id}}\",\n  \"platform\": \"android\",\n  \"app_version\": \"2.4.1\",\n  \"device_model\": \"Samsung Galaxy S24\",\n  \"os_version\": \"14\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/notifications/devices/register/", "host": ["{{base_url}}"], "path": ["api","notifications","devices","register",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ok:true', () => pm.expect(pm.response.json().ok).to.be.true);"
                ]
              }
            }
          ]
        },
